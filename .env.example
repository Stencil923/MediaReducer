# Copy to .env and adjust for your setup.

# ── Docker (docker-compose reads these to mount host folders) ────────────────
# Host paths that get mounted to the container's /library, /tautulli, etc.
# The /mnt/user/... values below are Unraid share paths — on any other host,
# point them at YOUR real folders, e.g.:
#   PLEX_LIBRARY_PATH=/srv/media          TAUTULLI_APPDATA=/opt/tautulli/config
#   MEDIAREDUCER_DATA=/opt/mediareducer
# NOTE: JELLYFIN_APPDATA and MEDIAREDUCER_DATA have Unraid defaults inside
# docker-compose.yml — if you are NOT on Unraid, set them here or Docker will
# silently create /mnt/user/appdata/... on your host.
PLEX_LIBRARY_PATH=/mnt/user/media
TAUTULLI_APPDATA=/mnt/user/appdata/tautulli
RADARR_APPDATA=/mnt/user/appdata/radarr
JELLYFIN_APPDATA=/mnt/user/appdata/jellyfin
MEDIAREDUCER_DATA=/mnt/user/appdata/mediareducer

# ── Running without Docker (the app reads these directly) ────────────────────
# Ignored under Docker — the container already mounts everything at the fixed
# paths below. Uncomment and point them wherever your files live to run as a
# bare `python3 app.py`. A real (exported) environment variable always wins.
# MEDIAREDUCER_LIBRARY=/mnt/tank/media
# MEDIAREDUCER_CONFIG=/home/me/.mediareducer/config.json
# MEDIAREDUCER_TAUTULLI_APPDATA=/opt/tautulli/config
# MEDIAREDUCER_RADARR_APPDATA=/opt/radarr/config
# MEDIAREDUCER_JELLYFIN_APPDATA=/var/lib/jellyfin
